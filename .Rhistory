### Tableau : taille et phénologie vérifiées
Dans cette partie, nous étudions la probabilité de transition du Sabot‑de‑Vénus.
plot_ly(
tx_erreur_fin,
x = ~tx_erreur,
y = ~risque_erreur,
z = ~(1 - tx_detect),
type = "scatter3d",
mode = "markers+text",
text = ~Observateur,
textposition = "top center",
marker = list(
size = 5,
color = ~ifelse(sexe.x == "f", "#E41A1C", "#377EB8"),
opacity = 0.8
),
hovertemplate = paste(
"<b>%{text}</b><br>",
"Sexe: %{customdata[0]}<br>",
"Taux erreur: %{x}<br>",
"Risque auto: %{y}<br>",
"Non-détection: %{z}<br>",
"<extra></extra>"
),
customdata = tx_erreur_fin[, c("sexe.x")]
) %>%
layout(
scene = list(
xaxis = list(title = "Taux d'erreur d'attribution"),
yaxis = list(title = "Risque d'erreur (auto-évaluation)"),
zaxis = list(title = "Taux de non-détection")
),
title = "Graphique 3D interactif des erreurs et de la non-détection"
)
# CORRÉLATION SPEARMAN
cor_spear <- cor.test(
tx_erreur_fin$tx_detect,
tx_erreur_fin$tx_erreur,
method = "spearman"
)
# MODÈLES LINÉAIRES
model1_autonotation <- lm(
risque_erreur ~ tx_erreur + tx_detect,
data = tx_erreur_fin
)
model2_autonotation <- lm(
risque_erreur ~ tx_detect,
data = tx_erreur_fin
)
model3_autonotation <- lm(
risque_erreur ~ tx_erreur,
data = tx_erreur_fin
)
# Avec variable d’apprentissage
model3_autonotation_app <- lm(
risque_erreur ~ tx_erreur + nb_detect,
data = tx_erreur_fin
)
# TABLEAU : COEFFICIENTS DES MODÈLES
tab_modeles <- list(
Model1 = tidy(model1_autonotation),
Model2 = tidy(model2_autonotation),
Model3 = tidy(model3_autonotation),
Model3_app = tidy(model3_autonotation_app)
)
kable(
do.call(rbind, lapply(names(tab_modeles), function(n) {
cbind(Model = n, tab_modeles[[n]])
})),
caption = "Coefficients et significativité des modèles linéaires",
digits = 4
) %>%
kable_styling(full_width = FALSE)
# TABLEAU : R² ET AIC DES MODÈLES
perf_models <- data.frame(
Model = c("Model1", "Model2", "Model3", "Model3_app"),
AIC = c(
AIC(model1_autonotation),
AIC(model2_autonotation),
AIC(model3_autonotation),
AIC(model3_autonotation_app)
),
R2 = c(
summary(model1_autonotation)$r.squared,
summary(model2_autonotation)$r.squared,
summary(model3_autonotation)$r.squared,
summary(model3_autonotation_app)$r.squared
)
)
kable(
perf_models,
caption = "Comparaison des modèles (AIC et R²)",
digits = 3
) %>%
kable_styling(full_width = FALSE)
library(tidyverse)      # manipulation de données, ggplot2, dplyr, tidyr, etc.
library(ggalluvial)     # diagrammes alluviaux (transitions, flux entre catégories)
library(lme4)           # modèles linéaires et mixtes
library(emmeans)        # prédictions de modèles linéaires
library(DHARMa)         # diagnostics de dispersion pour GLM/GLMM
library(performance)    # R² et autres métriques de performance de modèles
library(stats)          # fonctions statistiques de base
library(plotly)         # graphiques interactifs
library(ggrepel)        # étiquettes non superposées sur ggplot
library(ggpmisc)        # annotations statistiques sur ggplot
library(MASS)           # outils statistiques avancés (LDA, GLM, distributions)
library(ade4)           # analyses multivariées écologiques (PCA, CA, RLQ)
library(tidyr)          # manipulation de tableaux
library(dplyr)          # manipulation de données
library(stringr)        # manipulation de chaînes de caractères
library(vegan)          # analyses écologiques : RDA, CCA, NMDS, PERMANOVA
library(car)            # diagnostics de modèles (VIF, tests type II/III)
library(RMark)          # interface pour capture-marquage-recapture
library(DiagrammeR)     # graphes et diagrammes (flowcharts, DAG)
library(rstatix)        # tables et tests statistiques propres
library(nnet)           # régression multinomiale
library(kableExtra)     # tableaux esthétiques pour HTML/PDF
library(broom.mixed)    # tidy pour modèles mixtes
plot_ly(
tx_erreur_fin,
x = ~tx_erreur,
y = ~risque_erreur,
z = ~(1 - tx_detect),
type = "scatter3d",
mode = "markers+text",
text = ~Observateur,
textposition = "top center",
marker = list(
size = 5,
color = ~ifelse(sexe.x == "f", "#E41A1C", "#377EB8"),
opacity = 0.8
),
hovertemplate = paste(
"<b>%{text}</b><br>",
"Sexe: %{customdata[0]}<br>",
"Taux erreur: %{x}<br>",
"Risque auto: %{y}<br>",
"Non-détection: %{z}<br>",
"<extra></extra>"
),
customdata = tx_erreur_fin[, c("sexe.x")]
) %>%
layout(
scene = list(
xaxis = list(title = "Taux d'erreur d'attribution"),
yaxis = list(title = "Risque d'erreur (auto-évaluation)"),
zaxis = list(title = "Taux de non-détection")
),
title = "Graphique 3D interactif des erreurs et de la non-détection"
)
# CORRÉLATION SPEARMAN
cor_spear <- cor.test(
tx_erreur_fin$tx_detect,
tx_erreur_fin$tx_erreur,
method = "spearman"
)
# MODÈLES LINÉAIRES
model1_autonotation <- lm(
risque_erreur ~ tx_erreur + tx_detect,
data = tx_erreur_fin
)
model2_autonotation <- lm(
risque_erreur ~ tx_detect,
data = tx_erreur_fin
)
model3_autonotation <- lm(
risque_erreur ~ tx_erreur,
data = tx_erreur_fin
)
# Avec variable d’apprentissage
model3_autonotation_app <- lm(
risque_erreur ~ tx_erreur + nb_detect,
data = tx_erreur_fin
)
# TABLEAU : COEFFICIENTS DES MODÈLES
tab_modeles <- list(
Model1 = tidy(model1_autonotation),
Model2 = tidy(model2_autonotation),
Model3 = tidy(model3_autonotation),
Model3_app = tidy(model3_autonotation_app)
)
kable(
do.call(rbind, lapply(names(tab_modeles), function(n) {
cbind(Model = n, tab_modeles[[n]])
})),
caption = "Coefficients et significativité des modèles linéaires",
digits = 4
) %>%
kable_styling(full_width = FALSE)
# TABLEAU : R² ET AIC DES MODÈLES
perf_models <- data.frame(
Model = c("Model1", "Model2", "Model3", "Model3_app"),
AIC = c(
AIC(model1_autonotation),
AIC(model2_autonotation),
AIC(model3_autonotation),
AIC(model3_autonotation_app)
),
R2 = c(
summary(model1_autonotation)$r.squared,
summary(model2_autonotation)$r.squared,
summary(model3_autonotation)$r.squared,
summary(model3_autonotation_app)$r.squared
)
)
kable(
perf_models,
caption = "Comparaison des modèles (AIC et R²)",
digits = 3
) %>%
kable_styling(full_width = FALSE)
